      r'^ws[-_]',           # WS-xxx (workstation)\n        r'^workstation[-_]',  # WORKSTATION-xxx\n        r'^desktop[-_]',      # DESKTOP-xxx\n        r'^laptop[-_]',       # LAPTOP-xxx\n        r'^vm[-_]',           # VM-xxx\n        r'^vdi[-_]',          # VDI-xxx\n        r'^dc[-_]',           # DC-xxx (domain controller)\n        r'^ad[-_]',           # AD-xxx\n        r'^host[-_]',         # HOST-xxx\n        r'^node[-_]',         # NODE-xxx\n        r'^win[-_]',          # WIN-xxx\n        r'^win[0-9]',         # WIN10, WIN11, etc.\n        r'^pc[0-9]',          # PC01, PC123\n        r'^[a-z]{2,4}[-_][a-z]{2,}[0-9]*$',  # Pattern type SPN-WSRV01\n    ]\n    \n    # Suffixes de domaines AD/internes courants\n    internal_suffixes = [\n        '.local', '.internal', '.lan', '.corp', '.ad', \n        '.intra', '.private', '.home', '.localdomain',\n        '.internal.company', '.ad.company'\n    ]\n    \n    # Vérifie si le hostname match un pattern de machine\n    for pattern in hostname_patterns:\n        if re.match(pattern, hostname):\n            return True\n    \n    # Vérifie si le domaine a un suffixe interne connu\n    for suffix in internal_suffixes:\n        if domain_lower.endswith(suffix):\n            # Si suffixe interne + format hostname.xxx.suffix -> probablement AD\n            return True\n    \n    # Détection heuristique: hostname avec tiret suivi de lettres/chiffres\n    # Ex: PC-MCAPARROS, SRV-DC01, etc.\n    if re.match(r'^[a-z]{2,10}[-_][a-z0-9]+$', hostname) and len(parts) >= 3:\n        return True\n    \n    return False\n\n# Catégories\ncategories = {\n    \"ip\": \"ip\",\n    \"domain\": \"domain\",\n    \"url\": \"url\",\n    \"sha256\": \"hash\"\n}\n\n# Conteneur final\nresults = {}\n\nfor ioc in raw_input:\n    output = {} \n    \n    data = ioc.get(\"data\", None)\n    data_type = ioc.get(\"data_type\", None)\n    \n    if data is None or data_type is None:\n        continue\n      \n    # Ignorer les IPs privées\n    if data_type.lower() == \"ip\" and ioc.get(\"is_private_ip\", false) == true:\n        continue\n    \n    # Ignorer les hostnames AD pour les domaines\n    if data_type.lower() == \"domain\" and is_ad_hostname(data):\n        continue\n    \n    data_type_lower = data_type.lower()\n    if \"sha\" in data_type_lower:\n        key = \"hash\"\n    else:\n        key = categories.get(data_type_lower, None)\n    \n    if key is not None:\n        if key not in results:\n            results[key] = {\n                \"found\": false,\n                \"values\": []\n            }\n        \n        output[\"found\"] = true\n        \n        if \"values\" in results[key]:\n            output[\"values\"] = results[key][\"values\"] + [data]\n        else:\n            output[\"values\"] = [data]\n        \n        results[key] = output\n\n# On ajoute les catégories manquantes si jamais vues\nall_cats = [\"ip\", \"domain\", \"url\", \"hash\"]\nfor cat in all_cats:\n    if cat not in results:\n        results[cat] = {\n            \"found\": false,\n            \"values\": []\n        }\n\nprint(json.dumps(results))","multiline":true,"multiselect":false,"options":null,"action_field":"","variant":"STATIC_VALUE","required":true,"configuration":false,"tags":null,"schema":{"type":"string"},"skip_multicheck":false,"value_replace":null,"unique_toggled":false,"error":"","hidden":false}],"execution_variable":{"description":"","id":"","name":"","value":""},"position":{"x":519.9607048722049,"y":458.4269671292514},"authentication_id":"","category":"Other","reference_url":"","sub_action":false,"run_magic_output":false,"run_magic_input":false,"execution_delay":0,"category_label":null,"suggestion":false,"parent_controlled":false,"source_workflow":"","source_execution":""}],"branches":[{"destination_id":"62814ad6-9b5f-4d17-bbd6-1edbd9b1bfd9","id":"53ebd4af-2a05-47e9-b2b8-be0f5d70ea32","source_id":"dbb31516-7ca9-49dc-9920-f5ae4e8f49b2","label":"","has_errors":false,"conditions":[],"decorator":fals